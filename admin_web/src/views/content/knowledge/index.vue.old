          }
          
          .tag-more {
            padding: 2px 8px;
            background: #e0e0e0;
            border-radius: 10px;
            font-size: 11px;
            color: #999;
          }
        }

        .card-footer {
          display: flex;
          justify-content: space-between;
          align-items: center;
          padding-top: 10px;
          border-top: 1px solid #f0f0f0;
          margin-top: auto; // 推到底部

          .card-stats {
            display: flex;
            gap: 15px;

            .stat-item {
              font-size: 12px;
              color: #999;
              display: flex;
              align-items: center;

    .pagination-container {
      margin-top: 30px;
      display: flex;
      justify-content: center;
    }
  }
}

// 详情弹窗样式
.detail-dialog {
  .detail-content {
    .info-section {
      .info-row {
        display: flex;
        padding: 12px 0;
        border-bottom: 1px solid #f0f0f0;

        &.full-width {
          flex-direction: column;

          .info-value {
            margin-top: 8px;
          }
        }

        .info-label {
          width: 120px;
          color: #666;
          flex-shrink: 0;
        }

        .info-value {
          flex: 1;
          color: #333;

          &.content-text {
            white-space: pre-wrap;
            line-height: 1.6;
          }
        }
      }
    }

    .files-list {
      .file-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px;
        border: 1px solid #e0e0e0;
        border-radius: 4px;
        margin-bottom: 10px;

        .file-info {
          display: flex;
          align-items: center;
          gap: 10px;
          flex: 1;

          i {
            font-size: 20px;
            color: #666;
          }

          .file-name {
            flex: 1;
            overflow: hidden;
            text-overflow: ellipsis;

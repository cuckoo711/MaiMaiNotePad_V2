              i {
                font-size: 13px;
              }
            }
          }
          
          .card-actions {
            .el-button {
              padding: 5px 12px;
              font-size: 12px;
            }
          }
        }
      }

      .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 60px 20px;
